import 'package:flutter/material.dart';

void main() {
  runApp(const MiApp());
}

class MiApp extends StatelessWidget {
  const MiApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'Version1',
      theme: ThemeData(useMaterial3: true, colorSchemeSeed: Colors.deepPurple),
      home: const PantallaPrincipal(),
    );
  }
}

class PantallaPrincipal extends StatefulWidget {
  const PantallaPrincipal({super.key});

  @override
  State<PantallaPrincipal> createState() => _PantallaPrincipalState();
}

class _PantallaPrincipalState extends State<PantallaPrincipal> {
  Color colorAppBar = Colors.deepPurple;
  bool sombraActiva = true;

  final List<Color> colores = [
    Colors.deepPurple,
    Colors.blue,
    Colors.green,
    Colors.red,
    Colors.orange,
  ];

  int indiceColor = 0;

  void cambiarColor() {
    setState(() {
      indiceColor = (indiceColor + 1) % colores.length;
      colorAppBar = colores[indiceColor];
    });
  }

  void mostrarMensaje() {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('scrolledUnderElevation: ${sombraActiva ? 4.0 : 0.0}'),
        backgroundColor: colorAppBar,
      ),
    );
  }

  void navegar() {
    Navigator.push(
      context,
      MaterialPageRoute(builder: (context) => const SegundaPantalla()),
    );
  }

  Widget itemGrid(IconData icono, String texto) {
    return Container(
      decoration: BoxDecoration(
        color: colorAppBar.withOpacity(0.7),
        borderRadius: BorderRadius.circular(20),
      ),
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Icon(icono, size: 50, color: Colors.white),
          const SizedBox(height: 10),
          Text(
            texto,
            style: const TextStyle(color: Colors.white, fontSize: 18),
          ),
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.deepPurple.shade50,

      appBar: AppBar(
        title: const Text('Login'),
        centerTitle: true,
        backgroundColor: colorAppBar,
        foregroundColor: Colors.white,

        elevation: sombraActiva ? 4 : 0,
        scrolledUnderElevation: sombraActiva ? 4 : 0,

        actions: [
          IconButton(
            icon: const Icon(Icons.color_lens),
            tooltip: 'Cambiar color',
            onPressed: cambiarColor,
          ),
          IconButton(
            icon: const Icon(Icons.info),
            tooltip: 'Mostrar SnackBar',
            onPressed: mostrarMensaje,
          ),
          IconButton(icon: const Icon(Icons.navigate_next), onPressed: navegar),
        ],
      ),

      body: Column(
        children: [
          SwitchListTile(
            title: const Text('Activar sombra AppBar'),
            value: sombraActiva,
            onChanged: (value) {
              setState(() {
                sombraActiva = value;
              });
            },
          ),

          Expanded(
            child: GridView.count(
              padding: const EdgeInsets.all(20),
              crossAxisCount: 2,
              crossAxisSpacing: 15,
              mainAxisSpacing: 15,
              children: [
                itemGrid(Icons.person, "Perfil"),
                itemGrid(Icons.settings, "Ajustes"),
                itemGrid(Icons.message, "Mensajes"),
                itemGrid(Icons.logout, "Salir"),
              ],
            ),
          ),
        ],
      ),
    );
  }
}

class SegundaPantalla extends StatelessWidget {
  const SegundaPantalla({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Inicio'),
        backgroundColor: Colors.deepPurple,
        foregroundColor: Colors.white,
      ),
      body: const Center(
        child: Text(
          'Has navegado a la página de Inicio',
          style: TextStyle(fontSize: 22, fontWeight: FontWeight.bold),
        ),
      ),
    );
  }
}
